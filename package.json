{
  "name": "loop",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "description": "One permanent conversation with an agent that builds your interface as you work.",
  "repository": {
    "type": "git",
    "url": "https://github.com/acoyfellow/loop"
  },
  "scripts": {
    "dev": "node scripts/start-dev.mjs",
    "dev:app": "vite dev --host 127.0.0.1 --port 5176",
    "dev:worker": "wrangler dev --config wrangler.local.jsonc --port 1337 --persist-to .wrangler/state",
    "build": "vite build",
    "deploy": "alchemy deploy --adopt",
    "destroy": "alchemy destroy",
    "prepare": "svelte-kit sync || echo ''",
    "postinstall": "node scripts/install-hooks.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p worker/tsconfig.json",
    "test": "vitest run",
    "e2e": "playwright test",
    "stress": "node tests/stress-api.mjs",
    "verify": "bun run check && bun run test && bun run build",
    "ship": "node scripts/ship.mjs --watch"
  },
  "dependencies": {
    "@cloudflare/think": "^0.7.3",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.49.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "agents": "^0.13.3",
    "ai": "^6.0.191",
    "alchemy": "^0.93.7",
    "better-auth": "^1.6.4",
    "drizzle-orm": "^0.45.1",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.1.18",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.94.0"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  },
  "license": "MIT"
}
