# Local development needs none of these; this file lists what production reads.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://loop.coey.dev
ALCHEMY_PASSWORD=replace-with-a-long-random-secret

# Workers AI model (defaults to @cf/moonshotai/kimi-k2.6).
LOOP_MODEL=@cf/moonshotai/kimi-k2.6

# Sign-up gate. When unset, sign-up is open (use that only locally).
LOOP_INVITE_PASSWORD=pool
# Alternative: comma-separated multiple invite passwords.
# LOOP_INVITE_PASSWORDS=pool,another-invite
